{
  "name": "speaker-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/clean-dist.mjs && tsc --noEmit && vite build && node scripts/create-route-fallbacks.mjs",
    "check:positioning": "node scripts/check-positioning.mjs",
    "analytics:report": "node scripts/analytics-report.mjs",
    "deploy:analytics": "wrangler deploy --config wrangler.analytics.jsonc",
    "test": "node --test tests/*.test.mjs",
    "test:analytics:smoke": "node scripts/smoke-analytics-endpoint.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.11",
    "wrangler": "^4.92.0"
  }
}
