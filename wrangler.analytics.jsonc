{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tama-the-signal-field-analytics",
  "main": "worker/analytics-only.js",
  "compatibility_date": "2026-07-11",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "analytics.tamathe.com",
      "custom_domain": true
    }
  ],
  "analytics_engine_datasets": [
    {
      "binding": "SITE_ANALYTICS",
      "dataset": "speaker_site_events_v1"
    }
  ]
}
